# CBT Platform - Production Environment Template
# Copy this to .env.production and fill in the real values

NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-domain.com

# Database
DATABASE_URL=postgres://user:password@localhost:5432/cbt_platform

# Auth
JWT_SECRET=your_super_secret_jwt_key

# Stripe
STRIPE_SECRET_KEY=sk_prod_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Paystack
PAYSTACK_SECRET_KEY=sk_prod_...
PAYSTACK_BASE_URL=https://api.paystack.co

# Email (for receipt/notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# AI Integration
OPENAI_API_KEY=sk-...
